  interactPrompt: {fileID: 8700917404657840324}
  animator: {fileID: 3079372841988234395}
  playerTag: Player
  greetingDelay: 0.6
  dialogueLines:
  - "> UYARI: Bu RAM b\xF6lgesi karars\u0131z.\n  Bitleri do\u011Fru s\u0131rala,
    sistem stabilize olur."
  - "> \u0130PUCU: 0'lar ve 1'ler tesad\xFCf de\u011Fil.\n  Her \u015Feyin bir dizisi
    var."
  - "> GE\xC7IT: T\xFCm puzzle'lar\u0131 \xE7\xF6z.\n  A\u015Fa\u011F\u0131daki kilit
    a\xE7\u0131lacak."
  - "> UNUTMA: CPU b\xF6lgesine girersen\n  geri d\xF6n\xFC\u015F yok. Haz\u0131r
    ol."
  greetingLine: "> DATA MINER_07 burada.\n  Konu\u015Fmak i\xE7in [ E ] bas."
  repeatLine: "> Sana s\xF6yleyeceklerimi s\xF6yledim.\n  Git i\u015Fini yap, PROCESS."
  hasBonusDialogue: 0
  bonusDialogueLines:
  - "> \u0130yi i\u015F. Kap\u0131 a\xE7\u0131ld\u0131.\n  CPU seni bekliyor."
