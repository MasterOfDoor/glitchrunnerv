# Geliştirici / deploy ortam değişkenleri
# Yerel: Bu dosyayı .env olarak kopyalayıp değerleri doldur (Assets/.env veya Assets/StreamingAssets/.env).
# Deploy: Bu değişkenleri sunucu/CI ortamında set edin; .env dosyasını build'e koymayın.

# Avalanche (Fuji testnet varsayılan)
AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
AVALANCHE_CHAIN_ID=43113

# Oyun token sözleşmesi (Fuji)
AVALANCHE_TOKEN_CONTRACT=

# Market ödemelerinin gideceği dağıtıcı cüzdan adresi
AVALANCHE_DISTRIBUTOR_ADDRESS=

# Sadece test için: cüzdan bağlamadan bu adres kullanılsın (Reown yokken)
# DEV_WALLET_ADDRESS=0xYourTestWalletAddress
